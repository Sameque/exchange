# Auto detect text files and perform LF normalization
* text=auto

# C# sources
*.cs text diff=csharp
*.csx text diff=csharp

# .NET projects
*.csproj text
*.props text
*.targets text
*.sln text eol=crlf
*.slnx text

# Config files
*.json text
*.yml text
*.yaml text
*.xml text
*.config text

# Angular
*.ts text
*.html text
*.css text

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows scripts
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Docker
Dockerfile text
docker-compose*.yml text

# Documentation
*.md text
*.txt text

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text

# Fonts
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary